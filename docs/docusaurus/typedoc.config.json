{
    "$schema": "https://typedoc.org/schema.json",
    "coverageOutputPath": "static/img/coverage",
    "entryPointStrategy": "expand",
    "entryPoints": [
        "../../src/plugin.ts",
        "../../src/_internal"
    ],
    "extends": [
        "typedoc-config-nick2bad4u/typedoc.json"
    ],
    "favicon": "./static/img/logo.svg",
    "gitRemote": "origin",
    "gitRevision": "main",
    "githubPages": true,
    "hideGenerator": false,
    "hostedBaseUrl": "https://nick2bad4u.github.io/eslint-plugin-github-actions-2/",
    "includeHierarchySummary": true,
    "json": "docs/typedoc.json",
    "name": "eslint-plugin-github-actions-2 Documentation",
    "out": "site-docs/developer/api",
    "prettierConfigFile": "../../prettier.config.mjs",
    "searchGroupBoosts": {
        "Classes": 1.5,
        "Functions": 1.2,
        "Interfaces": 1.3,
        "Types": 1.1
    },
    "searchInComments": true,
    "searchInDocuments": true,
    "tsconfig": "tsconfig.typedoc.json"
}
